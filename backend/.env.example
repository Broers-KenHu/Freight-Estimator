DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-local-only
DJANGO_DEBUG=True
AUTH_ALLOW_DEV_USER=True

DATABASE_URL=sqlite:///db.sqlite3
POSTGRES_CONNECT_TIMEOUT=8
POSTGRES_CONN_MAX_AGE=120
POSTGRES_CONN_HEALTH_CHECKS=True
POSTGRES_STATEMENT_TIMEOUT_MS=90000
POSTGRES_LOCK_TIMEOUT_MS=10000
POSTGRES_IDLE_IN_TRANSACTION_TIMEOUT_MS=60000
POSTGRES_APPLICATION_NAME=freight-intelligence
DJANGO_DISABLE_SERVER_SIDE_CURSORS=False

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MSAL_TENANT_ID=
MSAL_AUDIENCE=
MSAL_AUDIENCES=
MSAL_ALLOW_UNVERIFIED_DEV_TOKENS=False

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

SQLSERVER_HOST=sqlserver-host
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=PostageCalculator
SQLSERVER_USER=
SQLSERVER_PASSWORD=

INVOICE_SQLSERVER_HOST=sqlserver-host
INVOICE_SQLSERVER_PORT=1433
